# === LLM ===
OPENAI_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# === LangSmith (optional but recommended) ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_replace_me
LANGCHAIN_PROJECT=langgraph-hitl-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === Postgres ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hitl
POSTGRES_USER=hitl
POSTGRES_PASSWORD=hitl

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# === Retry budgeting ===
RETRY_BUDGET_PER_THREAD=5
RETRY_BUDGET_WINDOW_SECONDS=300
